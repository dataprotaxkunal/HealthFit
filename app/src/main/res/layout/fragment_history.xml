<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Health History"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"/>

        <!-- Glucose Summary -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🩸 Blood Glucose Summary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/card_glucose"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_glucose_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Glucose Readings: 0"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_glucose_avg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tv_glucose_breakdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BP Summary -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💓 Blood Pressure Summary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/card_bp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_bp_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total BP Readings: 0"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_bp_avg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Activity Summary -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏃 Activity Summary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/card_steps"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_activity_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Activities Logged: 0"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_activity_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
